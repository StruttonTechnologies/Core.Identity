<Project Sdk="Microsoft.NET.Sdk">
	<!-- Package identity -->
	<PropertyGroup>
		<PackageId>StruttonTechnologies.Core.Identity.EF</PackageId>
		<Description>Entity Framework stores and context for StruttonTechnologies.Core.Identity.</Description>
		<Title>StruttonTechnologies.Core.Identity EF Integration</Title>
		<PackageTags>core,identity,ef,entityframework,stores,strutton,StruttonTechnologies</PackageTags>

		<!-- Versioning -->
		<VersionPrefix>1.0.0</VersionPrefix>
		<VersionSuffix>alpha</VersionSuffix>
	</PropertyGroup>
	<ItemGroup>
		<PackageReference Include="Microsoft.AspNetCore.Identity.EntityFrameworkCore" />
		<PackageReference Include="Microsoft.EntityFrameworkCore.Tools">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
		<PackageReference Include="StruttonTechnologies.Core.ToolKit.GuardKit" />
	</ItemGroup>
	<ItemGroup>
		<ProjectReference Include="..\StruttonTechnologies.Core.Identity.Domain.Contracts\StruttonTechnologies.Core.Identity.Domain.Contracts.csproj" />
		<ProjectReference Include="..\StruttonTechnologies.Core.Identity.Domain\StruttonTechnologies.Core.Identity.Domain.csproj" />
	</ItemGroup>
</Project>